# Ejemplo de Variables de Entorno
# Copia este archivo como .env.local y actualiza los valores según tu configuración

# ==========================================
# API Configuration
# ==========================================

# URL base del backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# URL completa del servidor (sin /api)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ==========================================
# Autenticación
# ==========================================

# Habilitar sistema de autenticación
NEXT_PUBLIC_AUTH_ENABLED=true

# Tiempo de expiración de sesión (en minutos)
# NEXT_PUBLIC_SESSION_TIMEOUT=30

# ==========================================
# Analytics (Opcional)
# ==========================================

# ID de Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ==========================================
# Ambiente
# ==========================================

# NODE_ENV puede ser: development, production, test
NODE_ENV=development

# ==========================================
# Desarrollo Local
# ==========================================

# Puerto en el que corre la aplicación
# Si dejas esto vacío, usará el puerto 3000 por defecto
# PORT=3000

# ==========================================
# Secrets (Nunca compartir públicamente)
# ==========================================

# Estos se usan solo en el servidor, no en el cliente
# No deben tener el prefijo NEXT_PUBLIC_

# API Secret (si es necesario para autenticación de servidor)
# API_SECRET=tu-secret-aqui

# ==========================================
# Configuración por Ambiente
# ==========================================

# Para Desarrollo Local
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Para Staging
# NEXT_PUBLIC_API_BASE_URL=https://staging-api.ejemplo.com/api

# Para Producción
# NEXT_PUBLIC_API_BASE_URL=https://api.ejemplo.com/api
